---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch all posts from the pages directory
const allPosts = await getCollection('pages', ({ id }) => {
	return id.startsWith('posts/');
});
---

<Layout title="My Portfolio">
	<main>
		<h1>Welcome to My Portfolio</h1>
		<p>Hi, I'm building cool things from scratch using Bun and Astro.</p>

		<hr />

		<h2>Recent Posts</h2>
		<ul>
			{allPosts.map((post) => (
				<li>
					<a href={`/${post.id.replace(/\.md$/, '')}`}>
						{post.data.title || post.id}
					</a>
				</li>
			))}
		</ul>
	</main>
</Layout>