---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch all posts from the posts content collection
const posts = await getCollection('posts');
---

<Layout title="My Portfolio">
	<header>
        <h1>Hi, I'm Leon</h1>
        <p>Welcome to my personal portfolio built completely from scratch.</p>
        <p>(⚠️ This is very much WIP)</p>
    </header>

    <main>
        <h2>My Projects</h2>
        <section>
            {posts.map((post, index) => (
                <>
                    <div class="project-card">
                        <h3>{post.data.title}</h3>
                        {post.data.description && <p>{post.data.description}</p>}
                        {post.data.github_url && (
                            <a href={post.data.github_url} target="_blank">View Code</a>
                        )}
                    </div>
                    {index < posts.length - 1 && <br />}
                </>
            ))}
        </section>
    </main>

    <footer class="fixed-footer">
        <p>© 2026 My Portfolio. All rights reserved.</p>
    </footer>
</Layout>