---
import Layout from '../layouts/Layout.astro';

// Fetch all markdown files inside the src/pages/posts/ directory
const allPosts = await Astro.glob('./posts/*.md');
---

<Layout title="My Portfolio">
	<main>
		<h1>Welcome to My Portfolio</h1>
		<p>Hi, I'm building cool things from scratch using Bun and Astro.</p>

		<hr />

		<h2>Recent Posts</h2>
		<ul>
			{allPosts.map((post) => (
				<li>
					<a href={post.url}>{post.frontmatter.title}</a>
				</li>
			))}
		</ul>
	</main>
</Layout>